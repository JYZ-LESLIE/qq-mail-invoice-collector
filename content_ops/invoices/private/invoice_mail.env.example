# Copy this file to invoice_mail.env and fill values locally.
# Do not paste real credentials into chat.

QQ_EMAIL=
QQ_IMAP_AUTH_CODE=
QQ_IMAP_HOST=imap.qq.com
QQ_IMAP_PORT=993
QQ_MAILBOX=INBOX
START_DATE=2026-01-01
END_DATE=

# Optional additional mailbox credentials for accounts.yaml.
ALIYUN_EMAIL=
ALIYUN_IMAP_AUTH_CODE=

# Vision fallback. Use LM Studio 30B-VL first, Ollama 8B-VL as local backup, MiMo as optional cloud backup.
VISION_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_VISION_MODEL=qwen3-vl-30b-a3b-instruct
LMSTUDIO_MAX_TOKENS=2048
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=qwen3-vl-8b-eagle:latest
OLLAMA_NUM_PREDICT=2048
MIMO_API_KEY=
MIMO_CHAT_COMPLETIONS_URL=https://api.xiaomimimo.com/v1/chat/completions
MIMO_MODEL=mimo-v2.5
MIMO_API_RETRIES=3
MIMO_API_RETRY_SLEEP_SECONDS=2
MIMO_CALIBRATION_MODE=0
MIMO_USER_AGENT=InvoiceSampleCalibration/1.0 (Local; Python)

# Network retry defaults for QQ IMAP.
RETRY_ATTEMPTS=3
RETRY_SLEEP_SECONDS=2
IMAP_TIMEOUT_SECONDS=60

# Optional: User-Agent for downloading invoice links from email body.
LINK_USER_AGENT=InvoiceCollector/1.0 (Local; Python)
